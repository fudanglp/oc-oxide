[Unit]
Description=oc-oxide OpenConnect daemon
Documentation=README.md
Wants=network-online.target
After=network-online.target systemd-resolved.service

[Service]
Type=simple
Environment=OC_OXIDE_PROFILE_DIR=/etc/oc-oxide/profiles
ExecStart=/usr/local/bin/oc-oxide-daemon serve
Restart=on-failure
RestartSec=2s
RuntimeDirectory=oc-oxide
RuntimeDirectoryMode=0700

[Install]
WantedBy=multi-user.target
